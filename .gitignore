# =============================================================================
# Python .gitignore for Arabic Reading Evaluation App
# =============================================================================

# -----------------------------------------------------------------------------
# Python Virtual Environment
# -----------------------------------------------------------------------------
venv/
env/
ENV/
.venv/

# -----------------------------------------------------------------------------
# Python Bytecode & Cache
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# -----------------------------------------------------------------------------
# Distribution / Packaging
# -----------------------------------------------------------------------------
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# -----------------------------------------------------------------------------
# Unit Test / Coverage Reports
# -----------------------------------------------------------------------------
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
.hypothesis/
.pytest_cache/

# -----------------------------------------------------------------------------
# Environment Variables
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local

# -----------------------------------------------------------------------------
# IDE - VS Code
# -----------------------------------------------------------------------------
.vscode/
*.code-workspace

# -----------------------------------------------------------------------------
# IDE - PyCharm / IntelliJ
# -----------------------------------------------------------------------------
.idea/
*.iml
*.iws

# -----------------------------------------------------------------------------
# macOS
# -----------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride

# -----------------------------------------------------------------------------
# Windows
# -----------------------------------------------------------------------------
Thumbs.db
ehthumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# Application Specific
# -----------------------------------------------------------------------------

# Generated audio files (TTS and saved recordings)
speeches/*.mp3
speeches/*.webm
speeches/*.wav
speeches/*.ogg
recordings/*.mp3
recordings/*.webm
recordings/*.wav
recordings/*.ogg
# Keep the .gitkeep files so the folder structure is preserved
!speeches/.gitkeep
!recordings/.gitkeep

# SQLite database
evaluations.db

# Logs
*.log
logs/
